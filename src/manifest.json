{
  "manifest_version": 3,
  "name": "Portals",
  "version": "1.0",
  "description": "Switch between localhost, staging, and production while preserving the current page.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Portals"
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "commands": {
    "switch_env_1": {
      "suggested_key": {
        "default": "Ctrl+Shift+1",
        "mac": "MacCtrl+Shift+1"
      },
      "description": "Switch to Environment 1 (e.g., Local)"
    },
    "switch_env_2": {
      "suggested_key": {
        "default": "Ctrl+Shift+2",
        "mac": "MacCtrl+Shift+2"
      },
      "description": "Switch to Environment 2 (e.g., Staging)"
    },
    "switch_env_3": {
      "suggested_key": {
        "default": "Ctrl+Shift+3",
        "mac": "MacCtrl+Shift+3"
      },
      "description": "Switch to Environment 3 (e.g., Production)"
    }
  }
}
